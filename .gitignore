# Python
__pycache__/
*.py[cod]
.venv/
venv/

# macOS
.DS_Store

# Logs
logs/*.log*
*.log

# Runtime output — mission recordings, photos, uploaded mission files
server/missions/
server/uploads/missions/*
!server/uploads/missions/.gitkeep
server/mission_library/*
!server/mission_library/.gitkeep

# Self-signed HTTPS cert/key (deploy/generate-cert.sh) — machine-specific,
# regenerated automatically on every boot; the private key must never be
# committed.
server/deploy/certs/

# IDE / local settings
.claude/
.idea/
.vscode/

# local configuration overrides
server/.env
