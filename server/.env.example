# DronAI configuration overrides (optional).
# Copy to server/.env and edit. Process environment variables take priority,
# then this file, then the defaults in config.py. Nothing is hardcoded.

# ── Wi-Fi (applied by deploy/install.sh) ─────────────────────────────
#WIFI_SSID=Coconut_ufi_97233
#WIFI_PASSWORD=1234567890

# ── Pixhawk UART ─────────────────────────────────────────────────────
#MAVLINK_PORT=/dev/serial0
#MAVLINK_BAUD=57600
# Rate (Hz) requested via REQUEST_DATA_STREAM on connect. Without this,
# ArduPilot only sends HEARTBEAT on a link — GPS/position/status telemetry
# requires an explicit stream request (QGroundControl always sends one).
#TELEMETRY_STREAM_RATE_HZ=4
# TEMP DEBUG: log every received HEARTBEAT/GPS_RAW_INT/GLOBAL_POSITION_INT/
# MISSION_CURRENT at INFO level, to compare live telemetry against QGC.
#LOG_TELEMETRY_RX=0

# ── Camera ───────────────────────────────────────────────────────────
#CAMERA_DEVICE=auto
#CAMERA_WIDTH=1280
#CAMERA_HEIGHT=720
#CAMERA_PITCH_DEG=-90.0
# Descriptive identity, recorded into EXIF/metadata (not auto-detectable
# from a generic UVC webcam).
#CAMERA_MODEL=Generic USB Camera
#CAMERA_SERIAL=unknown
#CAMERA_LENS=unknown

# ── Camera intelligence: quality scoring, validation, EXIF ────────────
# Minimum combined sharpness confidence (0..1) a captured frame must clear.
#QUALITY_CONFIDENCE_THRESHOLD=0.35
# Per-waypoint capture retries when the frame scores below threshold.
#CAPTURE_RETRY_LIMIT=2
# Pre-flight validation burst gating AUTO mode (mavlink/health.py). Mission
# start is blocked if the best of the burst never clears the threshold.
#CAMERA_VALIDATION_ENABLED=1
#CAMERA_VALIDATION_FRAME_COUNT=10
#CAMERA_VALIDATION_RETRY_LIMIT=1
# Consecutive byte-identical frames before the capture thread treats the
# camera as frozen and forces a reopen.
#CAMERA_FROZEN_FRAME_THRESHOLD=15
# Embed GPS/mission/quality metadata as EXIF into every captured JPEG.
#EXIF_ENABLED=1

# ── Mission automation ───────────────────────────────────────────────
# CAPTURE_STRATEGY=hover is the default: position-hold-and-shoot at every
# survey waypoint. "continuous" (never stops, distance/time-triggered) is
# reserved for future use.
#CAPTURE_STRATEGY=hover
#HOVER_HOLD_TIME_S=2.0
#PHOTO_CAPTURE_MODE=distance
#PHOTO_DISTANCE_M=10.0
#RECORDING_ENABLED=1
#MISSIONS_DIR=/home/pi/DronAi/server/missions

# ── Pre-arm / pre-AUTO safety thresholds ─────────────────────────────
#MIN_BATTERY_VOLTAGE=22.2
#MIN_BATTERY_PERCENT=20
#MIN_GPS_SATELLITES=6
#REQUIRED_GPS_FIX=3

# ── Server ───────────────────────────────────────────────────────────
#HOST=0.0.0.0
#PORT=8000
