# Copy to .env and rebuild (npm run build) to apply.

# Backend base URL. Leave unset in production — the built app is served by
# the same FastAPI process it talks to, so relative paths just work. Only
# set this in development to point at a real Pi's IP instead of localhost:8000.
# VITE_API_BASE_URL=http://192.168.1.50:8000

# ── Satellite imagery provider ──────────────────────────────────────────────
# Default is Esri World Imagery (free, no key, ~z19 native resolution in most
# regions). For sharper imagery at deep zoom (individual plants/rows), plug
# in a licensed provider that supports it — nothing else in the app needs to
# change, only these three values:
#
# MapTiler Satellite (up to ~z20, needs a free/paid API key):
# VITE_SATELLITE_TILE_URL=https://api.maptiler.com/tiles/satellite-v2/{z}/{x}/{y}.jpg?key=YOUR_KEY
# VITE_SATELLITE_MAX_ZOOM=20
# VITE_SATELLITE_ATTRIBUTION=© MapTiler
#
# Mapbox Satellite (up to ~z22, needs an access token):
# VITE_SATELLITE_TILE_URL=https://api.mapbox.com/v4/mapbox.satellite/{z}/{x}/{y}@2x.jpg90?access_token=YOUR_TOKEN
# VITE_SATELLITE_MAX_ZOOM=22
# VITE_SATELLITE_ATTRIBUTION=© Mapbox
#
# VITE_SATELLITE_TILE_URL=
# VITE_SATELLITE_MAX_ZOOM=19
# VITE_SATELLITE_ATTRIBUTION=
