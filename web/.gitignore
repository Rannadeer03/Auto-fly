# Logs (anchored to the project root — a bare "logs" pattern would also
# match src/features/logs/, silently excluding real source files from every
# commit; that's exactly what happened to src/features/logs/hooks/use-logs.ts)
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
